# Exam System Configuration
SECRET_KEY=change_this_to_a_long_random_secret_before_running
APP_ENV=development
FLASK_ENV=development
PORT=8000

# Database
DATABASE_URL=
DATABASE_PROVIDER=sqlite

# Security Settings
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
PREFERRED_URL_SCHEME=http
TRUST_PROXY_HEADERS=false
ADMIN_IDLE_TIMEOUT_SECONDS=7200
EXPIRED_EXAM_SWEEP_BACKGROUND=true
EXPIRED_EXAM_SWEEP_SECONDS=30

# Optional production/multi-process storage
REDIS_URL=
RATE_LIMIT_STORAGE=memory
# Development can fail open if Redis is unavailable. Production defaults to fail closed.
RATE_LIMIT_FAIL_OPEN=true
SESSION_TYPE=secure-cookie
SESSION_REDIS_URL=
SESSION_KEY_PREFIX=exam-session:

# Node migration backend
JWT_SECRET=change_this_to_a_long_random_jwt_secret
REFRESH_TOKEN_SECRET=change_this_to_a_long_random_refresh_secret

# Python Code Execution
CODE_EXECUTION_TIMEOUT_SECONDS=10
CODE_EXECUTION_MAX_CHARS=12000
CODE_EXECUTION_STDIN_MAX_CHARS=4000
CODE_EXECUTION_OUTPUT_MAX_CHARS=8000
CODE_EXECUTION_MODE=subprocess
CODE_EXECUTION_DOCKER_IMAGE=python:3.11-alpine
CODE_EXECUTION_MEMORY_MB=128
# Development convenience only. Production defaults to false unless explicitly enabled.
CODE_EXECUTION_ALLOW_UNSAFE_SUBPROCESS=True

# Admin Settings
ADMIN_REQUIRE_EXAM_START=True
TEACHER_CAN_VIEW_RESULTS=True

